#!/usr/bin/env bash
# Launch Claude Code sandboxed to the cc-fasrc writable tree.
# Every invocation applies the guard hook + deny rules from config.env.
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
. "$HERE/config.env"

# CC reads settings.json + the guard hook from here (NOT your real ~/.claude),
# so these sandbox rules apply to `cc` only and don't touch other CC usage.
export CLAUDE_CONFIG_DIR="$CC_HOME/.claude"
export CC_SANDBOX_DIR
export TMPDIR="$CC_SANDBOX_DIR/.tmp"; mkdir -p "$TMPDIR"

# Headless auth if a key file was dropped (keeps it out of shell history).
if [ -f "$CC_HOME/.claude/api-key" ]; then
  ANTHROPIC_API_KEY="$(cat "$CC_HOME/.claude/api-key")"; export ANTHROPIC_API_KEY
fi

# Always start inside the sandbox so relative work can't wander.
case "$PWD/" in
  "$CC_SANDBOX_DIR"/*) : ;;
  *) cd "$CC_SANDBOX_DIR" ;;
esac

exec "${CLAUDE_BIN:-claude}" --permission-mode "${CC_MODE:-acceptEdits}" "$@"
