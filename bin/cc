#!/usr/bin/env bash
# Launch Claude Code with the cc-fasrc native sandbox (writes confined to the
# sandbox tree by bubblewrap; Slurm commands excluded so sbatch works natively).
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
. "$HERE/config.env"

# CC reads settings.json (which enables the sandbox) from here, NOT your real
# ~/.claude — so these rules apply to `cc` only.
export CLAUDE_CONFIG_DIR="$CC_HOME/.claude"

# Headless auth if a key file was dropped (keeps it out of shell history).
if [ -f "$CC_HOME/.claude/api-key" ]; then
  ANTHROPIC_API_KEY="$(cat "$CC_HOME/.claude/api-key")"; export ANTHROPIC_API_KEY
fi

# Always start inside the sandbox tree.
case "$PWD/" in
  "$CC_SANDBOX_DIR"/*) : ;;
  *) cd "$CC_SANDBOX_DIR" ;;
esac

exec "${CLAUDE_BIN:-claude}" --permission-mode "${CC_MODE:-auto}" "$@"
