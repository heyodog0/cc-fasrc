#!/usr/bin/env bash
# Isolated mode: Claude Code inside the Apptainer sandbox (HARD write boundary)
# plus the host-side Slurm submit proxy. Use this instead of `cc` when you want a
# kernel-enforced boundary rather than the permission-guard default.
#
#   cc-iso            # ensures proxyd is up, then launches sealed CC
#
# Reqs: built image (apptainer build cc.sif cc.def) — see README "Apptainer mode".
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
. "$HERE/config.env"

# 1. Host-side proxy must be running so in-container sbatch/squeue work.
"$HERE/bin/cc-proxyd" start

# 2. Launch the sealed container (only the sandbox tree is writable).
exec "$HERE/lib/cc-sandbox" "$@"
