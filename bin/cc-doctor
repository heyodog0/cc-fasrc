#!/usr/bin/env bash
# cc-fasrc preflight — run on a FASRC login node after install.sh.
# Verifies everything the native sandbox depends on. Prints PASS/FAIL/WARN.
set -uo pipefail
HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
[ -f "$HERE/config.env" ] || { echo "FAIL: no config.env — run ./install.sh first"; exit 1; }
. "$HERE/config.env"

fail=0
ok()   { printf '  \033[32mPASS\033[0m %s\n' "$1"; }
no()   { printf '  \033[31mFAIL\033[0m %s\n' "$1"; fail=1; }
warn() { printf '  \033[33mWARN\033[0m %s\n' "$1"; }

echo "cc-fasrc doctor — sandbox: $CC_SANDBOX_DIR"
echo

# 1. login node, not a job
[ -z "${SLURM_JOB_ID:-}" ] && ok "on a login node (no SLURM_JOB_ID)" \
  || no "inside a SLURM job — CC's bash tool needs a login node (see issue #21026)"

# 2. core tooling
command -v tmux >/dev/null && ok "tmux: $(command -v tmux)" || no "tmux missing (cc-up needs it)"
command -v "${CLAUDE_BIN:-claude}" >/dev/null \
  && ok "claude: $("${CLAUDE_BIN:-claude}" --version 2>/dev/null | head -1)" \
  || no "claude not found — install it (npm i -g @anthropic-ai/claude-code)"

# 3. THE sandbox enforcement deps: bubblewrap + working unprivileged userns
if command -v bwrap >/dev/null; then ok "bubblewrap: $(command -v bwrap)"
else no "bwrap missing — native sandbox can't enforce (install bubblewrap)"; fi
if unshare --user --map-root-user true 2>/dev/null; then ok "unprivileged user namespaces work"
else no "user namespaces blocked — native sandbox can't start (failIfUnavailable=true will refuse)"; fi

# 4. slurm client present (excludedCommands lets these run unsandboxed)
command -v sbatch >/dev/null && command -v squeue >/dev/null \
  && ok "slurm client: $(command -v sbatch)" \
  || warn "sbatch/squeue not on PATH here — load it or check you're on a submit host"

# 5. sandbox tree writable
probe="$CC_SANDBOX_DIR/.cc/.doctor.$$"
if touch "$probe" 2>/dev/null; then ok "sandbox tree is writable"; rm -f "$probe"
else no "cannot write to $CC_SANDBOX_DIR"; fi

# 6. settings.json valid + sandbox actually enabled
CFG="$CC_HOME/.claude/settings.json"
if [ -f "$CFG" ] && python3 -c "import json,sys;json.load(open(sys.argv[1]))" "$CFG" 2>/dev/null; then
  if python3 -c "import json,sys;d=json.load(open(sys.argv[1]));sys.exit(0 if d.get('sandbox',{}).get('enabled') else 1)" "$CFG"; then
    ok "settings.json valid + sandbox.enabled=true"
  else no "settings.json present but sandbox.enabled is not true"; fi
else no "settings.json missing/invalid at $CFG"; fi

# 7. auth present (headless or stored)
D="$CC_HOME/.claude"
if [ -n "${ANTHROPIC_API_KEY:-}" ] || [ -f "$D/api-key" ] || [ -f "$D/.credentials.json" ]
then ok "auth configured (key or stored credentials)"
else warn "no API key / stored login — first 'cc' will need an interactive OAuth URL"; fi

echo
echo "Manual check the doctor CANNOT do for you — start 'cc', then:"
echo "  1. ask it to write to a path OUTSIDE the sandbox (e.g. ~/SBX.txt under your"
echo "     real \$HOME) — bubblewrap must BLOCK it."
echo "  2. ask it to run 'squeue -u \$USER' and 'sbatch --test-only <a job script>'"
echo "     — both must WORK (excludedCommands runs Slurm verbs unsandboxed)."
echo
[ "$fail" -eq 0 ] && echo "=> all hard checks passed." || { echo "=> fix the FAIL items above."; exit 1; }
