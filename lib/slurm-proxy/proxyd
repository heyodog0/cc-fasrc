#!/usr/bin/env python3
"""cc-fasrc host-side Slurm submit proxy — runs OUTSIDE the Apptainer container.

Brokers an allowlist of Slurm verbs for a CC instance confined to the sandbox.
Transport: files in $CC_SLURM_PROXY_DIR (a shared subdir of the sandbox tree),
so it works over Lustre/NFS where inotify/sockets don't.

TRUST BOUNDARY. This is the privileged side. CC (in the container) can only
request the verbs in ALLOWED; args go to the real binary with NO shell; sbatch
scripts must resolve INSIDE the sandbox; `--wrap` inline commands are refused;
every request is appended to proxyd.log. With CC_PROXY_MODE=hold, an sbatch is
held until a human runs `cc-approve <id>`.

Run:  CC_SANDBOX_DIR=... [CC_PROXY_MODE=auto|hold] proxyd
(normally started for you by `cc-proxyd start` / `cc-iso`).
"""
import glob
import json
import os
import shutil
import signal
import subprocess
import sys
import time

ALLOWED = {"sbatch", "squeue", "sacct", "scancel", "sinfo", "scontrol"}
POLL = 0.2
RUN_TIMEOUT = 120

SANDBOX = os.environ.get("CC_SANDBOX_DIR", "")
PROXY = os.environ.get("CC_SLURM_PROXY_DIR") or (
    os.path.join(SANDBOX, ".cc", "slurm-proxy") if SANDBOX else "")
MODE = os.environ.get("CC_PROXY_MODE", "auto")        # auto | hold
REQ = os.path.join(PROXY, "requests")
RESD = os.path.join(PROXY, "results")
DONE = os.path.join(PROXY, "processed")
APPROVE = os.path.join(PROXY, "approve")
LOG = os.path.join(PROXY, "proxyd.log")

_running = True


def _stop(*_):
    global _running
    _running = False


signal.signal(signal.SIGTERM, _stop)
signal.signal(signal.SIGINT, _stop)


def log(msg):
    with open(LOG, "a") as f:
        f.write(f"{time.strftime('%Y-%m-%dT%H:%M:%S')} {msg}\n")


def real_bin(verb):
    """Resolve the real Slurm binary on the host, skipping any proxy shim dir."""
    for d in os.environ.get("PATH", "").split(os.pathsep):
        if "slurm-proxy" in d:
            continue
        p = os.path.join(d, verb)
        if os.path.isfile(p) and os.access(p, os.X_OK):
            return p
    return shutil.which(verb)


def under_sandbox(path, cwd):
    if not os.path.isabs(path):
        path = os.path.join(cwd, path)
    rp = os.path.realpath(path)
    rs = os.path.realpath(SANDBOX)
    return rp == rs or rp.startswith(rs + os.sep)


# sbatch options that consume the following token (so it isn't the script)
_OPTS_WITH_VAL = {"-p", "--partition", "-A", "--account", "-t", "--time",
                  "-o", "--output", "-e", "--error", "-J", "--job-name",
                  "-c", "--cpus-per-task", "-n", "--ntasks", "-N", "--nodes",
                  "--mem", "--gres", "-d", "--dependency", "-C", "--constraint",
                  "--mail-type", "--mail-user", "--qos", "--reservation"}


def sbatch_script_ok(argv, cwd):
    """Find the batch script arg and require it to live inside the sandbox."""
    i = 1
    while i < len(argv):
        a = argv[i]
        if a == "--wrap" or a.startswith("--wrap="):
            return False, "sbatch --wrap inline commands are not allowed; submit a script inside the sandbox"
        if a.startswith("-"):
            if a in _OPTS_WITH_VAL and "=" not in a:
                i += 2
            else:
                i += 1
            continue
        return (True, a) if under_sandbox(a, cwd) else (False, f"sbatch script '{a}' is outside the sandbox")
    return False, "no batch script found in sbatch args"


def handle(req):
    rid = req.get("id")
    argv = req.get("argv") or []
    cwd = req.get("cwd") or SANDBOX
    if not under_sandbox(cwd, cwd):
        cwd = SANDBOX
    verb = (argv[0] if argv else "").strip()
    pretty = " ".join(argv)

    if verb not in ALLOWED:
        log(f"REJECT {rid} verb not allowed: {pretty}")
        return {"id": rid, "exit": 126, "stdout": "",
                "stderr": f"cc-fasrc proxy: verb '{verb}' not allowed\n"}

    if verb == "sbatch":
        ok, info = sbatch_script_ok(argv, cwd)
        if not ok:
            log(f"REJECT {rid} {info} :: {pretty}")
            return {"id": rid, "exit": 126, "stdout": "",
                    "stderr": f"cc-fasrc proxy: {info}\n"}
        if MODE == "hold":
            marker = os.path.join(APPROVE, rid)
            log(f"HOLD   {rid} {pretty} (cwd={cwd})")
            sys.stderr.write(f"[proxyd] HOLD {rid}: {pretty}\n          approve: cc-approve {rid}\n")
            sys.stderr.flush()
            while _running and not os.path.exists(marker) and not os.path.exists(marker + ".deny"):
                time.sleep(0.3)
            if os.path.exists(marker + ".deny"):
                os.remove(marker + ".deny")
                log(f"DENY   {rid}")
                return {"id": rid, "exit": 1, "stdout": "",
                        "stderr": "cc-fasrc proxy: submission denied by human\n"}
            if os.path.exists(marker):
                os.remove(marker)

    rb = real_bin(verb)
    if not rb:
        return {"id": rid, "exit": 127, "stdout": "",
                "stderr": f"cc-fasrc proxy: real '{verb}' not found on host PATH\n"}
    try:
        r = subprocess.run([rb] + argv[1:], cwd=cwd, capture_output=True,
                           text=True, timeout=RUN_TIMEOUT, env=os.environ.copy())
        log(f"RUN    {rid} exit={r.returncode} {pretty} (cwd={cwd})")
        return {"id": rid, "exit": r.returncode, "stdout": r.stdout, "stderr": r.stderr}
    except subprocess.TimeoutExpired:
        log(f"TIMEOUT {rid} {pretty}")
        return {"id": rid, "exit": 124, "stdout": "",
                "stderr": f"cc-fasrc proxy: '{verb}' timed out after {RUN_TIMEOUT}s\n"}
    except Exception as e:  # noqa: BLE001
        log(f"ERROR  {rid} {e}")
        return {"id": rid, "exit": 1, "stdout": "", "stderr": f"cc-fasrc proxy: {e}\n"}


def write_result(res):
    tmp = os.path.join(RESD, res["id"] + ".json.tmp")
    fin = os.path.join(RESD, res["id"] + ".json")
    with open(tmp, "w") as f:
        json.dump(res, f)
    os.rename(tmp, fin)


def main():
    if not PROXY:
        sys.stderr.write("cc-fasrc proxyd: set CC_SANDBOX_DIR or CC_SLURM_PROXY_DIR\n")
        sys.exit(2)
    for d in (REQ, RESD, DONE, APPROVE):
        os.makedirs(d, exist_ok=True)
    log(f"proxyd start mode={MODE} proxy={PROXY} pid={os.getpid()}")
    sys.stderr.write(f"[proxyd] watching {REQ} (mode={MODE}, pid={os.getpid()})\n")
    sys.stderr.flush()
    while _running:
        for path in sorted(glob.glob(os.path.join(REQ, "*.json")), key=os.path.getmtime):
            try:
                with open(path) as f:
                    req = json.load(f)
            except Exception:        # partial write; retry next tick
                time.sleep(0.05)
                continue
            write_result(handle(req))
            try:
                os.replace(path, os.path.join(DONE, os.path.basename(path)))
            except OSError:
                try:
                    os.remove(path)
                except OSError:
                    pass
        time.sleep(POLL)
    log("proxyd stop")


if __name__ == "__main__":
    main()
